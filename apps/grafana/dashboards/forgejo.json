{
  "schemaVersion": 39,
  "title": "Forgejo",
  "uid": "forgejo01",
  "tags": [
    "forgejo",
    "git"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Repositories",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "${datasource}",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "${datasource}",
            "uid": "${datasource}"
          },
          "expr": "gitea_repositories{job=\"forgejo\"}",
          "legendFormat": "Repos",
          "refId": "A"
        }
      ]
    },
